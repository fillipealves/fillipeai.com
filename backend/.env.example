# Gerado automaticamente pelo Railway ao adicionar o plugin PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Gere uma string aleatória longa (ex: openssl rand -hex 32)
JWT_SECRET=troque_por_uma_string_secreta_longa

# Tempo de expiração do token (ex: 7d, 24h, 30d)
JWT_EXPIRES_IN=7d

# Origem permitida pelo CORS (sua URL no Vercel)
CORS_ORIGIN=https://fillipeai.com

# Porta (Railway define automaticamente)
PORT=3000
